# SimpleStock - .env.example
# Copy this file to .env and adjust values for your environment.

# MySQL
DATABASE_URL="mysql://root:root@localhost:3306/simplestock"

# JWT
JWT_SECRET="REPLACE_WITH_32_CHAR_SECRET"
JWT_REFRESH_SECRET="REPLACE_WITH_32_CHAR_REFRESH_SECRET"
JWT_EXPIRES_IN="15m"
REFRESH_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development

# CORS (comma-separated)
CORS_ORIGIN="http://localhost:3000,http://localhost:5500"
